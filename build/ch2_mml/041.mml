<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><mi>α</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> è reale ed è </mtext><mspace width="0.333em"></mspace></mrow><mo>≥</mo><mn>0</mn></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><mi>α</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mn>0</mn><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> se e solo se </mtext><mspace width="0.333em"></mspace></mrow><mo stretchy="false" form="prefix">|</mo><mi>α</mi><mo stretchy="false" form="postfix">⟩</mo><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> è il vettore nullo</mtext></mrow></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><mi>β</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><msup><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>β</mi><mo stretchy="true" form="infix">|</mo><mi>α</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow></mrow></msup></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><msub><mi>β</mi><mn>1</mn></msub><mo>+</mo><msub><mi>β</mi><mn>2</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><msub><mi>β</mi><mn>1</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>+</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><msub><mi>β</mi><mn>2</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
\left\langle \alpha \middle| \alpha \right\rangle\text{  è reale ed è } \geq 0 \\
\left\langle \alpha \middle| \alpha \right\rangle = 0\text{  se e solo se }|\alpha\rangle\text{ è il vettore nullo} \\
\left\langle \alpha \middle| \beta \right\rangle = \left\langle \beta \middle| \alpha \right\rangle^{} \\
\left\langle \alpha \middle| \beta_{1} + \beta_{2} \right\rangle = \left\langle \alpha \middle| \beta_{1} \right\rangle + \left\langle \alpha \middle| \beta_{2} \right\rangle
\end{array}</annotation></semantics></math>