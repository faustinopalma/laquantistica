<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msup><mrow><mo stretchy="true" form="prefix">|</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mi>ϕ</mi></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup><mo>=</mo><msup><mtext mathvariant="normal">sen</mtext><mn>2</mn></msup><mfrac><mrow><mi>ϕ</mi><mo>−</mo><mi>ϑ</mi></mrow><mn>2</mn></mfrac></mrow><annotation encoding="application/x-tex">\left| \left\langle m_{\phi} = - k \middle| m_{\vartheta}\text{=+}k \right\rangle \right|^{2} = \text{sen}^{2}\frac{\phi - \vartheta}{2}</annotation></semantics></math>