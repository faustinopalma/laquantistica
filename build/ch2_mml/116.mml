<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|m_{\text{90}} = - k\rangle</annotation></semantics></math>