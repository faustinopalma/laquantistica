<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><msub><mi>λ</mi><mn>2</mn></msub><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mi>α</mi><mn>2</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>+</mo><mtext mathvariant="normal">...</mtext><mo>+</mo><msub><mi>λ</mi><mi>n</mi></msub><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mi>α</mi><mi>n</mi></msub><mo stretchy="true" form="postfix">⟩</mo></mrow></mrow><annotation encoding="application/x-tex">\left\langle \alpha_{1} \middle| \alpha_{1} \right\rangle = \lambda_{2}\left\langle \alpha_{1} \middle| \alpha_{2} \right\rangle + \text{...} + \lambda_{n}\left\langle \alpha_{1} \middle| \alpha_{n} \right\rangle</annotation></semantics></math>