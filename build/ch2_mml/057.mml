<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><mi>v</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><msub><mi>c</mi><mn>1</mn></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><mtext mathvariant="normal">...</mtext><mo>+</mo><msub><mi>c</mi><mi>n</mi></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>α</mi><mi>n</mi></msub><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|v\rangle = c_{1}|\alpha_{1}\rangle + \text{...} + c_{n}|\alpha_{n}\rangle</annotation></semantics></math>