<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mi>t</mi><mo stretchy="true" form="infix">|</mo><mi>β</mi><mi>t</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">\left\langle \alpha t \middle| \beta t \right\rangle</annotation></semantics></math>