<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><msub><mi>c</mi><mo>+</mo></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><msub><mi>c</mi><mo>−</mo></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|{\alpha t}_{0}\rangle = |m_{\vartheta}\text{=+}k\rangle = c_{+}|m_{\text{90}}\text{=+}k\rangle + c_{-}|m_{\text{90}} = - k\rangle</annotation></semantics></math>