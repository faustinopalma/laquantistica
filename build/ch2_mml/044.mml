<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><mi>β</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mn>0</mn><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> </mtext><mspace width="0.333em"></mspace></mrow><mo>⇔</mo><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> sono ortogonali</mtext></mrow></mrow><annotation encoding="application/x-tex">\left\langle \alpha \middle| \beta \right\rangle = 0\text{   } \Leftrightarrow \text{   sono ortogonali}</annotation></semantics></math>