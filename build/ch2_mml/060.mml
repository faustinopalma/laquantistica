<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mi>k</mi></msub><mo stretchy="true" form="infix">|</mo><mi>v</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><msub><mi>c</mi><mi>k</mi></msub><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mi>k</mi></msub><mo stretchy="true" form="infix">|</mo><msub><mi>α</mi><mi>k</mi></msub><mo stretchy="true" form="postfix">⟩</mo></mrow></mrow><annotation encoding="application/x-tex">\left\langle \alpha_{k} \middle| v \right\rangle = c_{k}\left\langle \alpha_{k} \middle| \alpha_{k} \right\rangle</annotation></semantics></math>