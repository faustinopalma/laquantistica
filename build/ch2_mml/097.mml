<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><msup><mrow><mo stretchy="true" form="prefix">|</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>g</mi><mo>=</mo><mover><mi>g</mi><mo accent="true">¯</mo></mover><mo stretchy="true" form="infix">|</mo><mi>α</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup><annotation encoding="application/x-tex">\left| \left\langle g = \overline{g} \middle| \alpha \right\rangle \right|^{2}</annotation></semantics></math>