<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|{\alpha t}_{0}\rangle = |m_{\vartheta}\text{=+}k\rangle</annotation></semantics></math>