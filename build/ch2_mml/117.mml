<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><mo stretchy="false" form="prefix">|</mo><mi>α</mi><mi>t</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><msub><mi>c</mi><mo>+</mo></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><msup><mi>e</mi><mrow><mi>i</mi><mi>ϕ</mi></mrow></msup><msub><mi>c</mi><mo>−</mo></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><msup><mi>e</mi><mrow><mi>i</mi><mi>ϕ</mi></mrow></msup><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">(</mo><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo stretchy="false" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="prefix">|</mo><mi>+</mi><msup><mi>e</mi><mrow><mi>i</mi><mi>ϕ</mi></mrow></msup><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo stretchy="false" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="prefix">|</mo><mo stretchy="true" form="postfix">)</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mi>U</mi><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
|\alpha t\rangle = c_{+}|m_{\text{90}}\text{=+}k\rangle + e^{i\phi}c_{-}|m_{\text{90}} = - k\rangle = \\
\left\langle m_{\text{90}}\text{=+}k \middle| {\alpha t}_{0} \right\rangle|m_{\text{90}}\text{=+}k\rangle + e^{i\phi}\left\langle m_{\text{90}} = - k \middle| {\alpha t}_{0} \right\rangle|m_{\text{90}} = - k\rangle = \\
\left( |m_{\text{90}}\text{=+}k\rangle\langle m_{\text{90}}\text{=+}k| + e^{i\phi}|m_{\text{90}} = - k\rangle\langle m_{\text{90}} = - k| \right)|{\alpha t}_{0}\rangle = \\
U|{\alpha t}_{0}\rangle
\end{array}</annotation></semantics></math>