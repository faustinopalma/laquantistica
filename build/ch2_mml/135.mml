<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">\left\langle {\alpha t}_{0} \middle| {\beta t}_{0} \right\rangle</annotation></semantics></math>