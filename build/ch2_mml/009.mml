<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>P</mi><mrow><msub><mi>m</mi><mn>0</mn></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi></mrow></msub><mo>=</mo><msup><mtext mathvariant="normal">cos</mtext><mn>2</mn></msup><mfrac><mi>ϕ</mi><mn>2</mn></mfrac></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>P</mi><mrow><msub><mi>m</mi><mn>0</mn></msub><mo>=</mo><mi>−</mi><mi>k</mi></mrow></msub><mo>=</mo><msup><mtext mathvariant="normal">sen</mtext><mn>2</mn></msup><mfrac><mi>ϕ</mi><mn>2</mn></mfrac></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
P_{m_{0}\text{=+}k} = \text{cos}^{2}\frac{\phi}{2} \\
P_{m_{0} = - k} = \text{sen}^{2}\frac{\phi}{2}
\end{array}</annotation></semantics></math>