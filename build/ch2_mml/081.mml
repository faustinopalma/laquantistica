<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mo stretchy="true" form="infix">|</mo><mi>α</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><msup><mrow><mo stretchy="true" form="prefix">|</mo><msub><mi>α</mi><mo>+</mo></msub><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup><mo>+</mo><msup><mrow><mo stretchy="true" form="prefix">|</mo><msub><mi>α</mi><mo>−</mo></msub><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup><mo>=</mo><mn>1</mn></mrow><annotation encoding="application/x-tex">\left\langle \alpha \middle| \alpha \right\rangle = \left| \alpha_{+} \right|^{2} + \left| \alpha_{-} \right|^{2} = 1</annotation></semantics></math>