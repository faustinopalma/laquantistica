<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><mo stretchy="false" form="prefix">|</mo><mi>α</mi><mi>t</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><mi>U</mi><mrow><mo stretchy="true" form="prefix">(</mo><msub><mi>t</mi><mn>0</mn></msub><mo>→</mo><mi>t</mi><mo stretchy="true" form="postfix">)</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>α</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mo stretchy="false" form="prefix">|</mo><mi>β</mi><mi>t</mi><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><mi>U</mi><mrow><mo stretchy="true" form="prefix">(</mo><msub><mi>t</mi><mn>0</mn></msub><mo>→</mo><mi>t</mi><mo stretchy="true" form="postfix">)</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="postfix">⟩</mo></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
|\alpha t\rangle = U\left( t_{0} \rightarrow t \right)|{\alpha t}_{0}\rangle \\
|\beta t\rangle = U\left( t_{0} \rightarrow t \right)|{\beta t}_{0}\rangle
\end{array}</annotation></semantics></math>