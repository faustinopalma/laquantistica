<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mn>0</mn></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mn>0</mn></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mn>0</mn></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mn>0</mn></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mn>0</mn></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mn>0</mn></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mn>0</mn></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mn>1</mn></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
\left\langle m_{0}\text{=+}k \middle| m_{0} = - k \right\rangle = 0 \\
\left\langle m_{0}\text{=+}k \middle| m_{0}\text{=+}k \right\rangle = \left\langle m_{0} = - k \middle| m_{0} = - k \right\rangle = 1
\end{array}</annotation></semantics></math>