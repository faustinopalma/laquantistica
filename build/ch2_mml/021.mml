<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">⟨</mo><mi>α</mi><mo stretchy="false" form="prefix">|</mo><mo>=</mo><mrow><mo stretchy="true" form="prefix">(</mo><msubsup><mi>α</mi><mn>1</mn><mrow></mrow></msubsup><mo>,</mo><msubsup><mi>α</mi><mn>2</mn><mrow></mrow></msubsup><mo stretchy="true" form="postfix">)</mo></mrow></mrow><annotation encoding="application/x-tex">\langle\alpha| = \left( \alpha_{1}^{},\alpha_{2}^{} \right)</annotation></semantics></math>