<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><msup><mrow><mo stretchy="true" form="prefix">|</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mi>ϕ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup><annotation encoding="application/x-tex">\left| \left\langle m_{\vartheta}\text{=+}k \middle| m_{\phi}\text{=+}k \right\rangle \right|^{2}</annotation></semantics></math>