<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mi>j</mi></msub><mo stretchy="true" form="infix">|</mo><msub><mi>α</mi><mi>k</mi></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mn>0</mn><mrow><mspace width="0.333em"></mspace><mtext mathvariant="normal"> </mtext><mspace width="0.333em"></mspace></mrow><mo>∀</mo><mi>j</mi><mo>≠</mo><mi>k</mi></mrow><annotation encoding="application/x-tex">\left\langle \alpha_{j} \middle| \alpha_{k} \right\rangle = 0\text{   }\forall j \neq k</annotation></semantics></math>