<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|m_{\vartheta} = - k\rangle</annotation></semantics></math>