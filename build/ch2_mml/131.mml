<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mrow><mo stretchy="true" form="prefix">(</mo><msup><mi>c</mi><mrow></mrow></msup><msubsup><mi>α</mi><mn>1</mn><mrow></mrow></msubsup><mo>,</mo><msup><mi>c</mi><mrow></mrow></msup><msubsup><mi>α</mi><mn>2</mn><mrow></mrow></msubsup><mo stretchy="true" form="postfix">)</mo></mrow><mo>=</mo><msup><mi>c</mi><mrow></mrow></msup><mrow><mo stretchy="true" form="prefix">(</mo><msubsup><mi>α</mi><mn>1</mn><mrow></mrow></msubsup><mo>,</mo><msubsup><mi>α</mi><mn>2</mn><mrow></mrow></msubsup><mo stretchy="true" form="postfix">)</mo></mrow><mo>=</mo><msup><mi>c</mi><mrow></mrow></msup><mo stretchy="false" form="prefix">⟨</mo><mi>α</mi><mo stretchy="false" form="prefix">|</mo></mrow><annotation encoding="application/x-tex">\left( c^{}\alpha_{1}^{},c^{}\alpha_{2}^{} \right) = c^{}\left( \alpha_{1}^{},\alpha_{2}^{} \right) = c^{}\langle\alpha|</annotation></semantics></math>