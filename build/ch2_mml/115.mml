<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>c</mi><mo>+</mo></msub><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>c</mi><mo>−</mo></msub><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mi>ϑ</mi></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
c_{+} = \left\langle m_{\text{90}}\text{=+}k \middle| m_{\vartheta}\text{=+}k \right\rangle \\
c_{-} = \left\langle m_{\text{90}} = - k \middle| m_{\vartheta}\text{=+}k \right\rangle
\end{array}</annotation></semantics></math>