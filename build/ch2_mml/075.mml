<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>P</mi><mrow><msub><mi>m</mi><mn>0</mn></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi></mrow></msub><mo>∝</mo><msup><mrow><mo stretchy="true" form="prefix">|</mo><msub><mi>α</mi><mo>+</mo></msub><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><msub><mi>P</mi><mrow><msub><mi>m</mi><mn>0</mn></msub><mo>=</mo><mi>−</mi><mi>k</mi></mrow></msub><mo>∝</mo><msup><mrow><mo stretchy="true" form="prefix">|</mo><msub><mi>α</mi><mo>−</mo></msub><mo stretchy="true" form="postfix">|</mo></mrow><mn>2</mn></msup></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
P_{m_{0}\text{=+}k} \propto \left| \alpha_{+} \right|^{2} \\
P_{m_{0} = - k} \propto \left| \alpha_{-} \right|^{2}
\end{array}</annotation></semantics></math>