<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><msub><mi>c</mi><mi>k</mi></msub><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>α</mi><mi>k</mi></msub><mo stretchy="true" form="infix">|</mo><mi>v</mi><mo stretchy="true" form="postfix">⟩</mo></mrow></mrow><annotation encoding="application/x-tex">c_{k} = \left\langle \alpha_{k} \middle| v \right\rangle</annotation></semantics></math>