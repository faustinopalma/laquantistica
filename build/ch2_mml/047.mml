<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>α</mi><mn>1</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>=</mo><msub><mi>λ</mi><mn>2</mn></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>α</mi><mn>2</mn></msub><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><mtext mathvariant="normal">...</mtext><mo>+</mo><msub><mi>λ</mi><mi>n</mi></msub><mo stretchy="false" form="prefix">|</mo><msub><mi>α</mi><mi>n</mi></msub><mo stretchy="false" form="postfix">⟩</mo></mrow><annotation encoding="application/x-tex">|\alpha_{1}\rangle = \lambda_{2}|\alpha_{2}\rangle + \text{...} + \lambda_{n}|\alpha_{n}\rangle</annotation></semantics></math>