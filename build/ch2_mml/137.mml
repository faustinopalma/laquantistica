<math display="inline" xmlns="http://www.w3.org/1998/Math/MathML"><semantics><mtable><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><mi>α</mi><mi>t</mi><mo stretchy="true" form="infix">|</mo><mi>β</mi><mi>t</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><msup><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow></mrow></msup><mo>+</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><msup><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow></mrow></msup><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>+</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="postfix">⟩</mo></mrow><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mo stretchy="false" form="prefix">⟨</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="false" form="prefix">|</mo><mrow><mo stretchy="true" form="prefix">(</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mtext mathvariant="normal">=+</mtext><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo>+</mo><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow><mo stretchy="false" form="prefix">|</mo><msub><mi>m</mi><mtext mathvariant="normal">90</mtext></msub><mo>=</mo><mi>−</mi><mi>k</mi><mo stretchy="false" form="postfix">⟩</mo><mo stretchy="true" form="postfix">)</mo></mrow><mo>=</mo></mtd></mtr><mtr><mtd columnalign="right" style="text-align: right"><mrow><mo stretchy="true" form="prefix">⟨</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="infix">|</mo><msub><mrow><mi>β</mi><mi>t</mi></mrow><mn>0</mn></msub><mo stretchy="true" form="postfix">⟩</mo></mrow></mtd></mtr></mtable><annotation encoding="application/x-tex">\begin{array}{r}
\left\langle \alpha t \middle| \beta t \right\rangle = \left\langle m_{\text{90}}\text{=+}k \middle| {\beta t}_{0} \right\rangle\left\langle m_{\text{90}}\text{=+}k \middle| {\beta t}_{0} \right\rangle^{} + \left\langle m_{\text{90}} = - k \middle| {\beta t}_{0} \right\rangle\left\langle m_{\text{90}} = - k \middle| {\beta t}_{0} \right\rangle^{} = \\
\left\langle m_{\text{90}}\text{=+}k \middle| {\beta t}_{0} \right\rangle\left\langle {\beta t}_{0} \middle| m_{\text{90}}\text{=+}k \right\rangle + \left\langle m_{\text{90}} = - k \middle| {\beta t}_{0} \right\rangle\left\langle {\beta t}_{0} \middle| m_{\text{90}} = - k \right\rangle = \\
\langle{\beta t}_{0}|\left( \left\langle m_{\text{90}}\text{=+}k \middle| {\beta t}_{0} \right\rangle|m_{\text{90}}\text{=+}k\rangle + \left\langle m_{\text{90}} = - k \middle| {\beta t}_{0} \right\rangle|m_{\text{90}} = - k\rangle \right) = \\
\left\langle {\beta t}_{0} \middle| {\beta t}_{0} \right\rangle
\end{array}</annotation></semantics></math>