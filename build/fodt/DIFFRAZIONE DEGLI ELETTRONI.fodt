   <text:p text:style-name="Standard">Questa equazione è risolta se si sceglie <draw:frame draw:style-name="fr15" draw:name="Object204" text:anchor-type="as-char" svg:width="1.1091in" svg:height="0.3953in" draw:z-index="192"><draw:object>
