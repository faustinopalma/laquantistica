   <text:p text:style-name="Standard">In genere si preferisce usare l’operatore <draw:frame draw:style-name="fr15" draw:name="Object98" text:anchor-type="as-char" svg:width="0.4701in" svg:height="0.1854in" draw:z-index="86"><draw:object>
