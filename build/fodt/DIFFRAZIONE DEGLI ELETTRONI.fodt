   <text:p text:style-name="Standard">Se prendiamo l’operatore inverso <draw:frame draw:style-name="fr15" draw:name="Object103" text:anchor-type="as-char" svg:width="0.2874in" svg:height="0.211in" draw:z-index="91"><draw:object>
