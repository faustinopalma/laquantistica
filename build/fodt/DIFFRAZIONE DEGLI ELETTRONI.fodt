              <mo fence="true" form="postfix" stretchy="true">)</mo>
             </mrow>
             <mo stretchy="false">=</mo>
             <mstyle mathvariant="italic">
              <mtext>iA</mtext>
             </mstyle>
            </mrow>
            <mrow>
             <mo fence="true" form="prefix" stretchy="true">(</mo>
             <mrow>
              <mi>t</mi>
             </mrow>
             <mo fence="true" form="postfix" stretchy="true">)</mo>
            </mrow>
           </mrow>
          </mstyle>
          <mrow/>
         </mrow>
         <annotation encoding="StarMath 5.0"> size 12{H left (t right )= ital &quot;iA&quot; left (t right )} {}</annotation>
        </semantics>
       </math>
