     </draw:image>
    </draw:frame><text:s/>al variare del tempo.</text:p>
   <text:p text:style-name="Standard">Per fare un confronto possiamo derivare dall’equazione di Shrödinger per le ampiezze <draw:frame draw:style-name="fr15" draw:name="Object134" text:anchor-type="as-char" svg:width="0.4791in" svg:height="0.2055in" draw:z-index="122"><draw:object>
