   <text:p text:style-name="Standard">Per trovare la soluzione abbiamo bisogno di alcuni risultati matematici molto utili che introduciamo ora:</text:p>
   <text:p text:style-name="P19">1<text:span text:style-name="T12">a</text:span> <text:s text:c="2"/><draw:frame draw:style-name="fr15" draw:name="Object169" text:anchor-type="as-char" svg:width="1.3091in" svg:height="0.4154in" draw:z-index="157"><draw:object>
