      <office:binary-data>AQAJAAADwgAAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAKgAoACEgAAACYGDwAaAP////8AABAAAADA////
