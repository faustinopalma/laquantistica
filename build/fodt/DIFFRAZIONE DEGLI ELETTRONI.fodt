   <text:p text:style-name="Standard">Ora confrontiamo le due equazioni per <draw:frame draw:style-name="fr15" draw:name="Object158" text:anchor-type="as-char" svg:width="0.5118in" svg:height="0.4465in" draw:z-index="146"><draw:object>
