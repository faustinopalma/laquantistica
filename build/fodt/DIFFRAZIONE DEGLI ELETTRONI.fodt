    </draw:frame></text:p>
   <text:p text:style-name="Standard">dove <draw:frame draw:style-name="fr15" draw:name="Object49" text:anchor-type="as-char" svg:width="0.6165in" svg:height="0.2457in" draw:z-index="37"><draw:object>
