   <text:p text:style-name="Standard">Dove abbiamo introdotto l’operatore <text:span text:style-name="T8">X</text:span> rappresentato dalla funzione <draw:frame draw:style-name="fr15" draw:name="Object137" text:anchor-type="as-char" svg:width="0.561in" svg:height="0.2327in" draw:z-index="125"><draw:object>
