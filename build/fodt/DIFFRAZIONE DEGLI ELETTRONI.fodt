          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ \langle u \lline } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADuAAAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAKgAkACEgAAACYGDwAaAP////8AABAAAADA////
       t////wACAABXAgAACwAAACYGDwAMAE1hdGhUeXBlAABwAAkAAAD6AgAAEAAAAAAAAAAiAAQA
       AAAtAQAABQAAABQCSQCpAAUAAAATAlABSAAFAAAAFAJQAUgABQAAABMCVwKpAAUAAAAUAkkA
       7wEFAAAAEwJXAu8BFQAAAPsCQP4AAAAAAACQAQEAAAAEAgAQVGltZXMgTmV3IFJvbWFuAABr
       BAAAAC0BAQAIAAAAMgrAAb8AAQAAAHUACgAAACYGDwAKAP////8BAAAAAAAQAAAA+wIUAAkA
       AAAAALwCAAAAAAECAiJTeXN0ZW0AAAQAAAAtAQIABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame>. Consideriamo ad esempio il caso a dimensione due</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr15" draw:name="Object69" text:anchor-type="as-char" svg:width="1.1028in" svg:height="0.3882in" draw:z-index="57"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mstyle mathsize="12pt">
         <mrow>
          <mrow>
           <mo stretchy="false">|</mo>
           <mi>u</mi>
           <mrow>
            <mo stretchy="false">⟩</mo>
            <mo stretchy="false">=</mo>
            <mrow/>
           </mrow>
           <mrow>
            <mtable>
             <mtr>
              <mtd>
               <mrow>
                <mrow>
                 <mo fence="true" form="prefix" stretchy="true">(</mo>
                 <mrow>
                  <mrow>
                   <mrow>
                    <msub>
                     <mi>u</mi>
