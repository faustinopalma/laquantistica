       AAAtAQAABQAAABQCSQBIAAUAAAATAlcCSAAFAAAAFAJJAJYBBQAAABMCUAH3AQUAAAAUAlAB
       9wEFAAAAEwJXApYBFQAAAPsCQP4AAAAAAACQAQEAAAAEAgAQVGltZXMgTmV3IFJvbWFuAACD
       BAAAAC0BAQAIAAAAMgrAAYsAAQAAAHUACgAAACYGDwAKAP////8BAAAAAAAQAAAA+wIUAAkA
       AAAAALwCAAAAAAECAiJTeXN0ZW0AAAQAAAAtAQIABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>dato dal prodotto tra una matrice <text:span text:style-name="T8">A</text:span> ed un altro vettore <draw:frame draw:style-name="fr15" draw:name="Object66" text:anchor-type="as-char" svg:width="0.2492in" svg:height="0.1945in" draw:z-index="54"><draw:object>
