       AAD7AhQACQAAAAAAvAIAAAAAAQICIlN5c3RlbQAABAAAAC0BAQAEAAAA8AEAAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>si ottiene coniugando e trasponendo la matrice <text:span text:style-name="T8">A</text:span>.</text:p>
   <text:p text:style-name="Standard">Per definizione diremo che la matrice <draw:frame draw:style-name="fr15" draw:name="Object77" text:anchor-type="as-char" svg:width="0.2453in" svg:height="0.211in" draw:z-index="65"><draw:object>
