   <text:p text:style-name="Standard">Ricordiamoci dell’ipotesi che abbiamo fatto <draw:frame draw:style-name="fr15" draw:name="Object205" text:anchor-type="as-char" svg:width="1.0626in" svg:height="0.2256in" draw:z-index="193"><draw:object>
