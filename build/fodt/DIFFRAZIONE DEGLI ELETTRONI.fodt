   <text:p text:style-name="Standard">Dimostriamo prima queste formule, dopo di ché risolveremo l’equazione nell’incognita <text:span text:style-name="T8">H</text:span>.</text:p>
   <text:h text:style-name="P18" text:outline-level="3">Dimostrazione delle formule 1<text:span text:style-name="T12">a</text:span>, 2<text:span text:style-name="T12">a</text:span>, 3<text:span text:style-name="T12">a</text:span> e 4<text:span text:style-name="T12">a</text:span>.</text:h>
