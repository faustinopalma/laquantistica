   <text:p text:style-name="Standard">Dove abbiamo usato la definizione <draw:frame draw:style-name="fr15" draw:name="Object247" text:anchor-type="as-char" svg:width="1.8283in" svg:height="0.1854in" draw:z-index="235"><draw:object>
