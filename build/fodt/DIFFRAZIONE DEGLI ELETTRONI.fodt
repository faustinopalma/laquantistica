          <mi mathvariant="normal">ℏ</mi>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ hbar } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
