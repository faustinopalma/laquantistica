   <text:p text:style-name="Standard">sottraendo ad ambo i membri <draw:frame draw:style-name="fr15" draw:name="Object51" text:anchor-type="as-char" svg:width="0.322in" svg:height="0.1945in" draw:z-index="39"><draw:object>
