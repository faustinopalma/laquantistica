   <text:p text:style-name="Standard">Questa equazione ammette soluzioni di tipo esponenziale complesso</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr15" draw:name="Object215" text:anchor-type="as-char" svg:width="1.952in" svg:height="0.3854in" draw:z-index="203"><draw:object>
