   <text:p text:style-name="Standard">Se ad esempio scegliamo <draw:frame draw:style-name="fr15" draw:name="Object224" text:anchor-type="as-char" svg:width="1.0453in" svg:height="0.2327in" draw:z-index="212"><draw:object>
