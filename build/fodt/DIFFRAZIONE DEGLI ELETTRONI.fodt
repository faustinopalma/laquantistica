   <text:p text:style-name="Standard">Calcoliamo ora la quantità di moto per una ampiezza di probabilità a distribuzione esponenziale<text:tab/></text:p>
   <text:p text:style-name="P19"><text:soft-page-break/><draw:frame draw:style-name="fr15" draw:name="Object238" text:anchor-type="as-char" svg:width="3.8665in" svg:height="1.0063in" draw:z-index="226"><draw:object>
