      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è la aggiunta della matrice <text:span text:style-name="T8">A</text:span>, e la indicheremo con il simbolo <draw:frame draw:style-name="fr15" draw:name="Object78" text:anchor-type="as-char" svg:width="0.2193in" svg:height="0.211in" draw:z-index="66"><draw:object>
