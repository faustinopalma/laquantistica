   <text:p text:style-name="Standard">e supponiamo di dover determinare il bra coniugato <draw:frame draw:style-name="fr15" draw:name="Object68" text:anchor-type="as-char" svg:width="0.2283in" svg:height="0.1945in" draw:z-index="56"><draw:object>
