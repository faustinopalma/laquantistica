      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>che possiamo rappresentare con un ket che dipende dal tempo <draw:frame draw:style-name="fr15" draw:name="Object36" text:anchor-type="as-char" svg:width="0.322in" svg:height="0.1945in" draw:z-index="24"><draw:object>
