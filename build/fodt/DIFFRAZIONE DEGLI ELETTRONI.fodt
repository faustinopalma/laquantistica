       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mi>ψ</mi>
           <mrow>
            <mo fence="true" form="prefix" stretchy="true">(</mo>
            <mrow>
             <mrow>
              <mi>x</mi>
              <mi>,</mi>
              <mi>t</mi>
             </mrow>
            </mrow>
            <mo fence="true" form="postfix" stretchy="true">)</mo>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ψ left (x,t right )} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADGgEAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAsAEEgAAACYGDwAaAP////8AABAAAADA////
