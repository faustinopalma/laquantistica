   <text:p text:style-name="Standard"><draw:frame draw:style-name="fr4" draw:name="Frame14" text:anchor-type="char" svg:x="4.2189in" svg:y="1.2291in" svg:width="0.9in" svg:height="0.5in" draw:z-index="298">
     <draw:text-box>
      <text:p text:style-name="Standard">Fig. 8</text:p>
     </draw:text-box>
    </draw:frame><draw:frame draw:style-name="fr4" draw:name="Frame15" text:anchor-type="char" svg:x="1.6189in" svg:y="1.2291in" svg:width="0.998in" svg:height="0.4in" draw:z-index="297">
     <draw:text-box>
      <text:p text:style-name="P4">Lamina di cristallo</text:p>
     </draw:text-box>
    </draw:frame><draw:line text:anchor-type="char" draw:z-index="296" draw:style-name="gr1" draw:text-style-name="P7" svg:x1="3.0189in" svg:y1="1.0291in" svg:x2="2.6189in" svg:y2="0.9291in">
     <text:p/>
    </draw:line><draw:line text:anchor-type="char" draw:z-index="295" draw:style-name="gr2" draw:text-style-name="P7" svg:x1="2.4189in" svg:y1="1.4291in" svg:x2="3.0189in" svg:y2="1.0291in">
     <text:p/>
    </draw:line>Come si vede dalla foto di figura 6 e dallo schema di figura 8, la lamina di cristallo è disposta direttamente sullo stadio finale del cannone elettronico.</text:p>
