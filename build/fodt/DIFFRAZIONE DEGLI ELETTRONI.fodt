   <text:p text:style-name="P9">L’equazione di evoluzione scritta in termini della matrice <text:span text:style-name="T8">H </text:span>appare così</text:p>
   <text:p text:style-name="P9"><text:tab/><draw:frame draw:style-name="fr15" draw:name="Object129" text:anchor-type="as-char" svg:width="1.3311in" svg:height="0.3953in" draw:z-index="117"><draw:object>
