           <mo stretchy="false">⟩</mo>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ \lline u \rangle } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
