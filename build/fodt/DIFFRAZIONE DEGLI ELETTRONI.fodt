           <mo stretchy="false">|</mo>
           <mi>w</mi>
           <mrow>
            <mo stretchy="false">⟩</mo>
            <mo stretchy="false">=</mo>
            <mi>R</mi>
           </mrow>
           <mo stretchy="false">|</mo>
           <mi>v</mi>
           <mo stretchy="false">⟩</mo>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ \lline w \rangle =R \lline v \rangle } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADBgEAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAKgAkAHEgAAACYGDwAaAP////8AABAAAADA////
       t////wAHAABXAgAACwAAACYGDwAMAE1hdGhUeXBlAABwAAkAAAD6AgAAEAAAAAAAAAAiAAQA
       AAAtAQAABQAAABQCSQBIAAUAAAATAlcCSAAFAAAAFAJJANwBBQAAABMCUAE9AgUAAAAUAlAB
       PQIFAAAAEwJXAtwBBQAAABQCSQBRBQUAAAATAlcCUQUFAAAAFAJJAIMGBQAAABMCUAHkBgUA
       AAAUAlAB5AYFAAAAEwJXAoMGFQAAAPsCQP4AAAAAAACQAQEAAAAEAgAQVGltZXMgTmV3IFJv
