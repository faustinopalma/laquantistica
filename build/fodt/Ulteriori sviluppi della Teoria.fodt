       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADIgEAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAgAHEgAAACYGDwAaAP////8AABAAAADA////
       t////8AGAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABAAAAD7Arz9CQEAAAAAkAEAAAAC
