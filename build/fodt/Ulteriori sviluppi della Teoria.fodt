      </office:binary-data>
     </draw:image>
    </draw:frame><text:tab/> è una matrice che dipende dal sistema e dalle “condizioni ambientali”. La matrice <draw:frame draw:style-name="fr3" draw:name="Object23" text:anchor-type="as-char" svg:width="0.6165in" svg:height="0.2457in" draw:z-index="17"><draw:object>
