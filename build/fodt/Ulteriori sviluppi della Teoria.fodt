                </mstyle>
               </msub>
               <mo stretchy="false">…</mo>
               <msub>
                <mi>k</mi>
                <mstyle mathsize="6pt">
                 <mi>n</mi>
                </mstyle>
               </msub>
              </mrow>
             </mstyle>
            </msub>
           </mstyle>
