          <mrow>
           <mstyle mathsize="12pt">
            <mrow>
             <msub>
              <mover accent="true">
               <mi>g</mi>
               <mo stretchy="false">¯</mo>
              </mover>
              <mstyle mathsize="8pt">
               <mn>1</mn>
              </mstyle>
             </msub>
             <mi>,</mi>
             <msub>
              <mover accent="true">
               <mi>g</mi>
               <mo stretchy="false">¯</mo>
              </mover>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msub>
             <mi>,</mi>
             <mtext>.</mtext>
             <mtext>.</mtext>
             <mtext>.</mtext>
             <msub>
              <mover accent="true">
               <mi>g</mi>
               <mo stretchy="false">¯</mo>
              </mover>
