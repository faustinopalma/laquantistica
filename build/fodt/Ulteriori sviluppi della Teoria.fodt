   <text:p text:style-name="Standard">Un set di grandezze fisiche <draw:frame draw:style-name="fr3" draw:name="Object45" text:anchor-type="as-char" svg:width="0.5047in" svg:height="0.222in" draw:z-index="39"><draw:object>
