      </office:binary-data>
     </draw:image>
    </draw:frame>, per esempio, associamo l’operatore <draw:frame draw:style-name="fr3" draw:name="Object217" text:anchor-type="as-char" svg:width="1.0154in" svg:height="0.222in" draw:z-index="217"><draw:object>
