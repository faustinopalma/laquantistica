      </draw:frame><text:s/>escano il particolare set di valori <text:s/><draw:frame draw:style-name="fr3" draw:name="Object77" text:anchor-type="as-char" svg:width="0.5909in" svg:height="0.2575in" draw:z-index="71"><draw:object>
