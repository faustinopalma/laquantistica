          <mrow>
           <mi>U</mi>
           <mrow>
            <mo fence="true" form="prefix" stretchy="true">(</mo>
            <mrow>
             <mrow>
              <msub>
               <mi>t</mi>
               <mstyle mathsize="8pt">
                <mn>0</mn>
               </mstyle>
              </msub>
              <mo stretchy="false">→</mo>
              <mi>t</mi>
             </mrow>
            </mrow>
            <mo fence="true" form="postfix" stretchy="true">)</mo>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
