       U3lzdGVtAAAEAAAALQEBAAQAAADwAQIAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame>, ed è non nulla solo se <draw:frame draw:style-name="fr3" draw:name="Object27" text:anchor-type="as-char" svg:width="0.3429in" svg:height="0.1854in" draw:z-index="21"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
