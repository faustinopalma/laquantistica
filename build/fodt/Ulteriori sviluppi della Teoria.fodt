            </msup>
           </mstyle>
           <mrow/>
          </mrow>
          <annotation encoding="StarMath 5.0"> size 12{ { {g}} sup { &apos; }} {}</annotation>
         </semantics>
        </math>
       </draw:object><draw:image>
        <office:binary-data>AQAJAAADrQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
         BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAgACEgAAACYGDwAaAP////8AABAAAADA////
         t////8ABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AkD+AAAAAAAAkAEBAAAA
