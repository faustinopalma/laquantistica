                <mrow>
                 <mtext>piano  {</mtext>
                 <mover accent="true">
                  <mi>y</mi>
                  <mo stretchy="false">¯</mo>
                 </mover>
                </mrow>
               </mstyle>
               <mover accent="true">
                <mi>z</mi>
                <mo stretchy="false">¯</mo>
               </mover>
              </mrow>
             </munder>
             <mrow/>
