   <text:p text:style-name="Standard"><text:soft-page-break/>cioè i vettori di stato <draw:frame draw:style-name="fr3" draw:name="Object137" text:anchor-type="as-char" svg:width="0.4898in" svg:height="0.222in" draw:z-index="137"><draw:object>
