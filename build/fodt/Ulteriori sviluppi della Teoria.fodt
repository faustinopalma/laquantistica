       AAAtAQAABQAAABQCSQBIAAUAAAATAlcCSAAFAAAAFAJJAM4BBQAAABMCUAEvAgUAAAAUAlAB
       LwIFAAAAEwJXAs4BEAAAAPsCQP4AAAAAAACQAQEAAAIEAgAQU3ltYm9sAAIEAAAALQEBAAgA
       AAAyCsABbwABAAAAYQAKAAAAJgYPAAoA/////wEAAAAAABAAAAD7AhQACQAAAAAAvAIAAAAA
       AQICIlN5c3RlbQAABAAAAC0BAgAEAAAA8AEBAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame>, quindi possiamo dedurre la formula</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object104" text:anchor-type="as-char" svg:width="1.9937in" svg:height="0.3811in" draw:z-index="98"><draw:object>
