       AAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è un insieme completo di grandezze osservabili, e <draw:frame draw:style-name="fr3" draw:name="Object186" text:anchor-type="as-char" svg:width="0.3244in" svg:height="0.2138in" draw:z-index="186"><draw:object>
