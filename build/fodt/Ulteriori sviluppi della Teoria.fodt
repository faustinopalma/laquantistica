         AABnAAoAAAAmBg8ACgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIiU3lzdGVt
         AAAEAAAALQEBAAQAAADwAQIAAwAAAAAA
        </office:binary-data>
       </draw:image>
      </draw:frame><text:s/>associato al numero considerato.</text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P4">In generale se il sistema si trova in uno stato <text:span text:style-name="T2"></text:span> e si misura una grandezza <draw:frame draw:style-name="fr3" draw:name="Object14" text:anchor-type="as-char" svg:width="0.1417in" svg:height="0.2091in" draw:z-index="8"><draw:object>
