   <text:p text:style-name="Standard">Quindi non possiamo parlare dello stato <draw:frame draw:style-name="fr3" draw:name="Object37" text:anchor-type="as-char" svg:width="0.3429in" svg:height="0.1854in" draw:z-index="31"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mi>x</mi>
           <mo stretchy="false">=</mo>
           <mover accent="true">
            <mi>x</mi>
            <mo stretchy="false">¯</mo>
           </mover>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{x= { bar  {x}}} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADzAAAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALAAQAEEgAAACYGDwAaAP////8AABAAAADA////
       9////8ADAAC3AQAACwAAACYGDwAMAE1hdGhUeXBlAAAwAAkAAAD6AgAAEAAAAAAAAAAiAAQA
       AAAtAQAABQAAABQCVQD3AgUAAAATAlUAuwMVAAAA+wJA/gAAAAAAAJABAQAAAAQCABBUaW1l
       cyBOZXcgUm9tYW4AAIMEAAAALQEBAAgAAAAyCmAB6QIBAAAAeAAIAAAAMgpgAU4AAQAAAHgA
       EAAAAPsCQP4AAAAAAACQAQAAAAIEAgAQU3ltYm9sAAIEAAAALQECAAQAAADwAQEACAAAADIK
       YAF8AQEAAAA9AAoAAAAmBg8ACgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIi
       U3lzdGVtAAAEAAAALQEBAAQAAADwAQIAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame>, perché non è uno solo, ma possiamo parlare dello stato <draw:frame draw:style-name="fr3" draw:name="Object38" text:anchor-type="as-char" svg:width="1.1634in" svg:height="0.1854in" draw:z-index="32"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mrow>
            <mi>x</mi>
            <mo stretchy="false">=</mo>
            <mover accent="true">
             <mi>x</mi>
             <mo stretchy="false">¯</mo>
            </mover>
           </mrow>
           <mi>,</mi>
           <mrow>
            <mi>y</mi>
            <mo stretchy="false">=</mo>
