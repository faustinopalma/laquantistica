   <text:p text:style-name="Standard">che dovendo essere vera per ogni <draw:frame draw:style-name="fr3" draw:name="Object194" text:anchor-type="as-char" svg:width="0.2752in" svg:height="0.1945in" draw:z-index="194"><draw:object>
