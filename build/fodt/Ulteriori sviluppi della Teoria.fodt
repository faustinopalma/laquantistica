       vAIAAAAAAQICIlN5c3RlbQAABAAAAC0BAQAEAAAA8AEAAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è detta matrice di evoluzione temporale e gode della proprietà di lasciare invariati i prodotti scalari<text:tab/><text:tab/><text:tab/><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object24" text:anchor-type="as-char" svg:width="1.2516in" svg:height="0.222in" draw:z-index="18"><draw:object>
