        </office:binary-data>
       </draw:image>
      </draw:frame>, è dato dalla formula <draw:frame draw:style-name="fr3" draw:name="Object151" text:anchor-type="as-char" svg:width="0.6516in" svg:height="0.1945in" draw:z-index="151"><draw:object>
