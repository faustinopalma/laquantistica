   <text:p text:style-name="Standard">determiniamo gli autostati dell’operatore <draw:frame draw:style-name="fr3" draw:name="Object146" text:anchor-type="as-char" svg:width="0.4898in" svg:height="0.222in" draw:z-index="146"><draw:object>
