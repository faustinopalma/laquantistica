          <mi>ρ</mi>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ρ} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADiAAAAAIAEgAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAaABEgAAACYGDwAaAP////8AABAAAADA////
       NwAAAGABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABAAAAD7AkD+AAAAAAAAkAEBAAAC
       BAIAEFN5bWJvbAACBAAAAC0BAAAIAAAAMgogAU4AAQAAAHIACgAAACYGDwAKAP////8BAAAA
       AAAQAAAA+wIUAAkAAAAAALwCAAAAAAECAiJTeXN0ZW0AAAQAAAAtAQEABAAAAPABAAADAAAA
       AAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>per non creare confusione con la <text:span text:style-name="T1">p</text:span> della quantità di moto.</text:p>
   <text:p text:style-name="Standard">In base a questa formula possiamo calcolare il valore medio:</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object114" text:anchor-type="as-char" svg:width="4.8354in" svg:height="0.9335in" draw:z-index="114"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mtable>
          <mtr>
           <mtd>
            <mrow>
             <mstyle mathsize="12pt">
              <mrow>
               <mrow>
                <mrow>
                 <mo fence="true" form="prefix" stretchy="false">⟨</mo>
