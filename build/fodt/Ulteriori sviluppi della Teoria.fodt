      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADjQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAYABEgAAACYGDwAaAP////8AABAAAADA////
       NwAAAEABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AkD+AAAAAAAAkAEBAAAA
