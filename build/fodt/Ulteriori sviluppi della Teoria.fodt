       MgogAgACAQAAAHgACAAAADIKIAJxAAEAAABwABAAAAD7AkD+AAAAAAAAkAEAAAACBAIAEFN5
       bWJvbAACBAAAAC0BAQAEAAAA8AECAAgAAAAyCiAC5gYBAAAAPQAKAAAAJgYPAAoA/////wEA
       AAAAABAAAAD7AhQACQAAAAAAvAIAAAAAAQICIlN5c3RlbQAABAAAAC0BAgAEAAAA8AEBAAMA
       AAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame></text:p>
   <text:p text:style-name="Standard">e poi calcolare l’integrale</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object65" text:anchor-type="as-char" svg:width="0.6528in" svg:height="0.5693in" draw:z-index="59"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
