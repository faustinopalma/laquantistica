        </office:binary-data>
       </draw:image>
      </draw:frame><text:s/>rappresentano gli autostati della grandezza <draw:frame draw:style-name="fr3" draw:name="Object155" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="155"><draw:object>
