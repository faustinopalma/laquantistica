    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P10">Gli autovalori dell’operatore <draw:frame draw:style-name="fr3" draw:name="Object152" text:anchor-type="as-char" svg:width="0.1437in" svg:height="0.1854in" draw:z-index="152"><draw:object>
