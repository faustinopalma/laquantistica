         CgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIiU3lzdGVtAAAEAAAALQEBAAQA
         AADwAQAAAwAAAAAA
        </office:binary-data>
       </draw:image>
      </draw:frame>, e gli autovettori associati ad un autovalore <draw:frame draw:style-name="fr3" draw:name="Object154" text:anchor-type="as-char" svg:width="0.1417in" svg:height="0.2091in" draw:z-index="154"><draw:object>
