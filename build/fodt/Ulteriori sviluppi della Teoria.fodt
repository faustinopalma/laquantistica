   <text:p text:style-name="Standard">Il ket associato allo stato <draw:frame draw:style-name="fr3" draw:name="Object48" text:anchor-type="as-char" svg:width="1.1634in" svg:height="0.1854in" draw:z-index="42"><draw:object>
