    <text:list-item>
     <text:p text:style-name="P4">L’evoluzione nel tempo di uno stato <text:span text:style-name="T2"></text:span><text:span text:style-name="T1">t</text:span> segue una legge lineare<text:tab/><text:tab/><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object21" text:anchor-type="as-char" svg:width="1.398in" svg:height="0.2457in" draw:z-index="15"><draw:object>
