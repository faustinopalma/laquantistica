    </text:list-item>
   </text:list>
   <text:p text:style-name="Standard">Dimostrazione:</text:p>
   <text:p text:style-name="Standard">Consideriamo una grandezza <draw:frame draw:style-name="fr3" draw:name="Object157" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="157"><draw:object>
