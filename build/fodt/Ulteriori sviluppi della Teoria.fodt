       AADwAQAAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è associato un operatore hermitiano <draw:frame draw:style-name="fr3" draw:name="Object148" text:anchor-type="as-char" svg:width="0.1437in" svg:height="0.1854in" draw:z-index="148"><draw:object>
