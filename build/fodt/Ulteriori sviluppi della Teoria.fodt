   <text:p text:style-name="Standard">Dove abbiamo indicato la probabilità con il simbolo <draw:frame draw:style-name="fr3" draw:name="Object113" text:anchor-type="as-char" svg:width="0.1146in" svg:height="0.1854in" draw:z-index="113"><draw:object>
