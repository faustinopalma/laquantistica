       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mi>g</mi>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{g} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADjQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAYABEgAAACYGDwAaAP////8AABAAAADA////
       NwAAAEABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AkD+AAAAAAAAkAEBAAAA
       BAIAEFRpbWVzIE5ldyBSb21hbgAAgwQAAAAtAQAACAAAADIKIAFOAAEAAABnAAoAAAAmBg8A
       CgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIiU3lzdGVtAAAEAAAALQEBAAQA
       AADwAQAAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>e del set di grandezze ausiliarie <draw:frame draw:style-name="fr3" draw:name="Object162" text:anchor-type="as-char" svg:width="0.1008in" svg:height="0.1854in" draw:z-index="162"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
