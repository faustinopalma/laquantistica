   <text:p text:style-name="Standard">Proviamo a moltiplicare l’operatore <draw:frame draw:style-name="fr3" draw:name="Object122" text:anchor-type="as-char" svg:width="0.1957in" svg:height="0.222in" draw:z-index="122"><draw:object>
