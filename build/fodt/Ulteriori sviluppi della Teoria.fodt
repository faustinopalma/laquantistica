         CgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIiU3lzdGVtAAAEAAAALQEBAAQA
         AADwAQAAAwAAAAAA
        </office:binary-data>
       </draw:image>
      </draw:frame>, quando il sistema si trova in uno stato rappresentato dal ket <draw:frame draw:style-name="fr3" draw:name="Object150" text:anchor-type="as-char" svg:width="0.2752in" svg:height="0.1945in" draw:z-index="150"><draw:object>
