        </office:binary-data>
       </draw:image>
      </draw:frame>, la probabilità che esca <draw:frame draw:style-name="fr3" draw:name="Object80" text:anchor-type="as-char" svg:width="1.0937in" svg:height="0.2457in" draw:z-index="74"><draw:object>
