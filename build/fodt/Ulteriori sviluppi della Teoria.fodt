       8AEBAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>non ha significato, infatti l’autovalore <draw:frame draw:style-name="fr3" draw:name="Object62" text:anchor-type="as-char" svg:width="0.1098in" svg:height="0.1854in" draw:z-index="56"><draw:object>
