       AAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>l’autostato associato a <draw:frame draw:style-name="fr3" draw:name="Object34" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="28"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mover accent="true">
           <mi>g</mi>
           <mo stretchy="false">¯</mo>
          </mover>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ { bar  {g}}} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADpAAAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAIgAqABEgAAACYGDwAaAP////8AABAAAADA////
       9////2ABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgAAkAAAD6AgAAEAAAAAAAAAAiAAQA
       AAAtAQAABQAAABQCVQBnAAUAAAATAlUARwEVAAAA+wJA/gAAAAAAAJABAQAAAAQCABBUaW1l
       cyBOZXcgUm9tYW4AAIMEAAAALQEBAAgAAAAyCmABTgABAAAAZwAKAAAAJgYPAAoA/////wEA
       AAAAABAAAAD7AhQACQAAAAAAvAIAAAAAAQICIlN5c3RlbQAABAAAAC0BAgAEAAAA8AEBAAMA
       AAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>sia unico, il ché in generale non è vero; ad esempio nel caso di una particella materiale nello spazio tridimensionale gli autostati associati ad un autovalore <draw:frame draw:style-name="fr3" draw:name="Object35" text:anchor-type="as-char" svg:width="0.1098in" svg:height="0.1854in" draw:z-index="29"><draw:object>
