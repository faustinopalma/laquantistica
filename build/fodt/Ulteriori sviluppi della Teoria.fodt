       BAAAAC0BAAAEAAAA8AEBAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>i possibili valori della grandezza <draw:frame draw:style-name="fr3" draw:name="Object159" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="159"><draw:object>
