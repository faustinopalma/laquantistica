   <text:h text:style-name="Heading_20_2" text:outline-level="2">Momento angolare.</text:h>
   <text:p text:style-name="Standard">Nella Fisica Classica il momento angolare rispetto ad un polo <text:span text:style-name="T1">O</text:span> è definito dalla formula </text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object195" text:anchor-type="as-char" svg:width="0.7646in" svg:height="0.222in" draw:z-index="195"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <msub>
            <mover accent="true">
             <mi>L</mi>
             <mo stretchy="false">¯</mo>
            </mover>
            <mstyle mathsize="8pt">
             <mi>O</mi>
            </mstyle>
           </msub>
           <mo stretchy="false">=</mo>
           <mrow>
            <msub>
             <mover accent="true">
              <mi>r</mi>
              <mo stretchy="false">¯</mo>
             </mover>
             <mstyle mathsize="8pt">
              <mi>O</mi>
             </mstyle>
            </msub>
            <mo stretchy="false">∧</mo>
            <mover accent="true">
             <mi>p</mi>
             <mo stretchy="false">¯</mo>
            </mover>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
