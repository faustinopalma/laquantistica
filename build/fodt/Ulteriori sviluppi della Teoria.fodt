         </semantics>
        </math>
       </draw:object><draw:image>
        <office:binary-data>AQAJAAADwwEAAAMAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
         BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgB6AHEgAAACYGDwAaAP////8AABAAAADA////
