      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>tale che esiste un unico autostato simultaneo associato agli autovalori <draw:frame draw:style-name="fr3" draw:name="Object46" text:anchor-type="as-char" svg:width="0.5047in" svg:height="0.222in" draw:z-index="40"><draw:object>
