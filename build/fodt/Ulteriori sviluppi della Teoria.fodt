    </draw:frame><text:s/>di <text:span text:style-name="T1">x</text:span> sono infiniti:</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object36" text:anchor-type="as-char" svg:width="1.8752in" svg:height="0.2055in" draw:z-index="30"><draw:object>
