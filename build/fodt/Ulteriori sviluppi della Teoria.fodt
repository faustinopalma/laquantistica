         <mstyle mathsize="12pt">
          <mrow>
           <mi>x</mi>
           <mo stretchy="false">≠</mo>
           <mover accent="true">
            <mi>x</mi>
            <mo stretchy="false">¯</mo>
           </mover>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{x &lt;&gt;  { bar  {x}}} {}</annotation>
       </semantics>
      </math>
