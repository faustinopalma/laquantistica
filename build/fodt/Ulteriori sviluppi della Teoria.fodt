   <text:p text:style-name="Standard">Questa formula ci mostra che l’operatore <draw:frame draw:style-name="fr3" draw:name="Object120" text:anchor-type="as-char" svg:width="0.1957in" svg:height="0.222in" draw:z-index="120"><draw:object>
