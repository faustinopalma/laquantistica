         <mstyle mathsize="12pt">
          <mrow>
           <mo stretchy="false">|</mo>
           <mi>ψ</mi>
           <mo stretchy="false">⟩</mo>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ \lline ψ \rangle } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADswAAAAMAEgAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAKgAqACEgAAACYGDwAaAP////8AABAAAADA////
