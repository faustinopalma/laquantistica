       AQICIlN5c3RlbQAABAAAAC0BAgAEAAAA8AEBAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>e gli autostati della quantità di moto.</text:p>
   <text:p text:style-name="Standard"><text:soft-page-break/>Per mantenere la generalità non possiamo ipotizzare che la grandezza <draw:frame draw:style-name="fr3" draw:name="Object109" text:anchor-type="as-char" svg:width="0.1854in" svg:height="0.222in" draw:z-index="103"><draw:object>
