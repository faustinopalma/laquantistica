     </draw:image>
    </draw:frame>? Possiamo scrivere <draw:frame draw:style-name="fr3" draw:name="Object60" text:anchor-type="as-char" svg:width="1.0098in" svg:height="0.2484in" draw:z-index="54"><draw:object>
