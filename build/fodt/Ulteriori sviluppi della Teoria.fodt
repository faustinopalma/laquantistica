       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADjQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAcABEgAAACYGDwAaAP////8AABAAAADA////
       1////4ABAAC3AQAACwAAACYGDwAMAE1hdGhUeXBlAAAwABUAAAD7AkD+AAAAAAAAkAEBAAAA
       BAIAEFRpbWVzIE5ldyBSb21hbgAAoAQAAAAtAQAACAAAADIKgAErAAEAAABHAAoAAAAmBg8A
       CgD/////AQAAAAAAEAAAAPsCFAAJAAAAAAC8AgAAAAABAgIiU3lzdGVtAAAEAAAALQEBAAQA
       AADwAQAAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>tale che:</text:p>
   <text:list text:style-name="WW8Num3">
    <text:list-item>
     <text:p text:style-name="P10">Il valore medio della grandezza <draw:frame draw:style-name="fr3" draw:name="Object149" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="149"><draw:object>
        <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
         <semantics>
          <mrow>
           <mstyle mathsize="12pt">
            <mi>g</mi>
           </mstyle>
           <mrow/>
          </mrow>
          <annotation encoding="StarMath 5.0"> size 12{g} {}</annotation>
         </semantics>
        </math>
       </draw:object><draw:image>
        <office:binary-data>AQAJAAADjQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
         BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAYABEgAAACYGDwAaAP////8AABAAAADA////
