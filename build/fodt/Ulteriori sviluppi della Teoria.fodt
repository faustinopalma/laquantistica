       SwIFAAAAEwJXAuoBEAAAAPsCQP4AAAAAAACQAQEAAAIEAgAQU3ltYm9sAAIEAAAALQEBAAgA
       AAAyCsABWgABAAAAeQAKAAAAJgYPAAoA/////wEAAAAAABAAAAD7AhQACQAAAAAAvAIAAAAA
       AQICIlN5c3RlbQAABAAAAC0BAgAEAAAA8AEBAAMAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame>, vengano i valori <draw:frame draw:style-name="fr3" draw:name="Object56" text:anchor-type="as-char" svg:width="1.052in" svg:height="0.1854in" draw:z-index="50"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mrow>
          <mstyle mathsize="12pt">
           <mrow>
            <mover accent="true">
             <mi>x</mi>
             <mo stretchy="false">¯</mo>
            </mover>
            <mtext>,  {</mtext>
            <mover accent="true">
             <mstyle mathvariant="italic">
              <mi>y</mi>
             </mstyle>
             <mo stretchy="false">¯</mo>
            </mover>
           </mrow>
          </mstyle>
          <mtext> e  {</mtext>
          <mover accent="true">
           <mstyle mathvariant="italic">
            <mi>z</mi>
           </mstyle>
           <mo stretchy="false">¯</mo>
          </mover>
         </mrow>
         <mrow/>
         <mrow>
          <mrow/>
