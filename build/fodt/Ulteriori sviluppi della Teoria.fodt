       AADwAQEACAAAADIKhgFeAQEAAACiAAoAAAAmBg8ACgD/////AQAAAAAAEAAAAPsCFAAJAAAA
       AAC8AgAAAAABAgIiU3lzdGVtAAAEAAAALQEBAAQAAADwAQAAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>assunto dalla grandezza <draw:frame draw:style-name="fr3" draw:name="Object111" text:anchor-type="as-char" svg:width="0.1854in" svg:height="0.222in" draw:z-index="111"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
