               </mstyle>
              </msup>
             </mrow>
            </mfrac>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{E rSub { size 8{n} } = -  {  { ital &quot;me&quot; rSup { size 8{4} } }  over  {8ε rSub { size 8{0} }  rSup { size 8{2} } h rSup { size 8{2} } n rSup { size 8{2} } } } } {}</annotation>
       </semantics>
      </math>
