   <text:p text:style-name="Standard">Ma se vogliamo la probabilità che misurando solo <text:span text:style-name="T1">x</text:span> venga <draw:frame draw:style-name="fr3" draw:name="Object59" text:anchor-type="as-char" svg:width="0.1098in" svg:height="0.1854in" draw:z-index="53"><draw:object>
