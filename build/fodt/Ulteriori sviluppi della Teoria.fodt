         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{p rSub { size 8{x} } } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADsgAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAiACEgAAACYGDwAaAP////8AABAAAADA////
       t////+ABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AiD/AAAAAAAAkAEBAAAA
       BAIAEFRpbWVzIE5ldyBSb21hbgAAfgQAAAAtAQAACAAAADIKEAJoAQEAAAB4ABUAAAD7AkD+
       AAAAAAAAkAEBAAAABAIAEFRpbWVzIE5ldyBSb21hbgAAfgQAAAAtAQEABAAAAPABAAAIAAAA
       MgqgAXEAAQAAAHAACgAAACYGDwAKAP////8BAAAAAAAQAAAA+wIUAAkAAAAAALwCAAAAAAEC
       AiJTeXN0ZW0AAAQAAAAtAQAABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame>).</text:p>
   <text:p text:style-name="Standard">In base a queste notazioni possiamo scrivere la probabilità:</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr3" draw:name="Object112" text:anchor-type="as-char" svg:width="2.8811in" svg:height="0.2598in" draw:z-index="112"><draw:object>
