         AADwAQAAAwAAAAAA
        </office:binary-data>
       </draw:image>
      </draw:frame><text:s/>sono tutti i possibili valori che può assumere la grandezza <draw:frame draw:style-name="fr3" draw:name="Object153" text:anchor-type="as-char" svg:width="0.1134in" svg:height="0.1854in" draw:z-index="153"><draw:object>
