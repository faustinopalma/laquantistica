       AADwAQAAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame>, siano <draw:frame draw:style-name="fr3" draw:name="Object158" text:anchor-type="as-char" svg:width="0.1417in" svg:height="0.2091in" draw:z-index="158"><draw:object>
