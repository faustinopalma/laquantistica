       U3lzdGVtAAAEAAAALQEBAAQAAADwAQIAAwAAAAAA
      </office:binary-data>
     </draw:image>
    </draw:frame>, supponendo di conoscere lo stato del sistema <draw:frame draw:style-name="fr3" draw:name="Object108" text:anchor-type="as-char" svg:width="0.2752in" svg:height="0.1945in" draw:z-index="102"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
