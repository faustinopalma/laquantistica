   <text:p text:style-name="Standard">Per impostare il problema di diffusione con l’equazione di Schrödinger dovremmo specificare il “pacchetto d’onda” iniziale, cioè la distribuzione di ampiezze di probabilità iniziale <draw:frame draw:style-name="fr8" draw:name="Object53" text:anchor-type="as-char" svg:width="1.4752in" svg:height="0.2917in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mo stretchy="false">|</mo>
           <msub>
            <mi mathvariant="italic">ψt</mi>
            <mstyle mathsize="8pt">
             <mn>0</mn>
            </mstyle>
           </msub>
           <mrow>
            <mo stretchy="false">⟩</mo>
            <mo stretchy="false">=</mo>
            <mi>ψ</mi>
           </mrow>
           <mrow>
            <mo fence="true" form="prefix" stretchy="true">(</mo>
            <mrow>
             <mrow>
              <mi>x</mi>
              <mi>,</mi>
              <mi>y</mi>
              <mi>,</mi>
              <mi>z</mi>
              <mi>,</mi>
              <msub>
               <mi>t</mi>
               <mstyle mathsize="8pt">
                <mn>0</mn>
               </mstyle>
              </msub>
             </mrow>
            </mrow>
            <mo fence="true" form="postfix" stretchy="true">)</mo>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
