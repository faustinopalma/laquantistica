        <annotation encoding="StarMath 5.0"> size 12{F=alignc { stack {
 left (&quot;Particelle per unità&quot; {} # 
 right ) left (&quot;di tempo in &quot;d %OMEGA  {} # 
 righ)} }  \(  \)  times  {  {π&quot;sen&quot; rSup { size 8{2} } &quot;10&quot;°}  over  {d %OMEGA } } =&quot;27&quot; times  {  {π&quot;sen&quot; rSup { size 8{2} } &quot;10&quot;°}  over  {d %OMEGA } }  approx  {  {2,5}  over  {d %OMEGA } } } {}</annotation>
