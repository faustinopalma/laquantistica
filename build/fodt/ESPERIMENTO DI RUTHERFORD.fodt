       ABAATGliZXJhdGlvbiBTZXJpZgAAAAAAAKAAAAAAAAAAAAAFAAAAAAAAAP8DAAAAAAAAAAEA
       /wMAAAAAAAAAAAAAAIgAAQACAAAAAQCHAAEABQAAAP////8AhgABAAQAAAAAAAAAcgACABcA
       AACmAAAAHgEAAAEAMVAAAAAAAAEAAQAxAIwAAQAAAAAAjAABAAAAAACMAAEAAAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame>, per procedere sostituiamo <draw:frame draw:style-name="fr8" draw:name="Object74" text:anchor-type="as-char" svg:width="0.2252in" svg:height="0.2665in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
