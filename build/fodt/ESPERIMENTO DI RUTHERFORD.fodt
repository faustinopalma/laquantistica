     <text:p text:style-name="P7" loext:marker-style-name="T4"><text:span text:style-name="T4">Lamina</text:span><text:span text:style-name="T4"/></text:p>
     <text:p text:style-name="P7" loext:marker-style-name="T4"><text:span text:style-name="T4">d’oro</text:span></text:p>
     <draw:enhanced-geometry draw:mirror-horizontal="false" draw:mirror-vertical="false" draw:glue-points="?f0 0 0 ?f1 ?f0 ?f2 ?f3 ?f1" draw:text-areas="0 0 ?f3 ?f2" svg:viewBox="0 0 0 0" draw:type="ooxml-rect" draw:enhanced-path="M 0 0 L ?f3 0 ?f3 ?f2 0 ?f2 Z N">
