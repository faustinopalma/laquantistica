   <text:p text:style-name="Standard">In questo modo troviamo una prima soluzione <draw:frame draw:style-name="fr8" draw:name="Object73" text:anchor-type="as-char" svg:width="0.2252in" svg:height="0.2665in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <msub>
           <mi>ψ</mi>
           <mstyle mathsize="8pt">
            <mn>1</mn>
           </mstyle>
          </msub>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ψ rSub { size 8{1} } } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
