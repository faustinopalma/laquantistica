   <text:p text:style-name="Standard">Il prodotto della densità del flusso per la sezione del fascio ci dà il flusso incidente totale <text:s/>che indicheremo con <text:span text:style-name="T6">F</text:span>, quindi abbiamo:</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr8" draw:name="Object109" text:anchor-type="as-char" svg:width="4.1in" svg:height="0.75in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mrow>
            <msub>
             <mi>w</mi>
             <mstyle mathsize="8pt">
              <mtext>Effettiva</mtext>
             </mstyle>
            </msub>
            <mo stretchy="false">=</mo>
            <mrow>
             <mi>F</mi>
             <mo stretchy="false">×</mo>
             <mi>s</mi>
             <mo stretchy="false">×</mo>
             <mi>n</mi>
             <mo stretchy="false">×</mo>
             <msub>
              <mi>w</mi>
              <mstyle mathsize="8pt">
               <mtext>Unitaria</mtext>
              </mstyle>
             </msub>
            </mrow>
            <mo stretchy="false">=</mo>
            <mstyle mathvariant="italic">
             <mtext>Fsn</mtext>
            </mstyle>
           </mrow>
           <mfrac>
            <mrow>
             <msup>
              <mi>q</mi>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msup>
             <msup>
              <mi>Q</mi>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msup>
            </mrow>
            <mrow>
             <mtext>64</mtext>
             <msup>
              <mi>π</mi>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msup>
             <msubsup>
              <mi>ε</mi>
              <mstyle mathsize="8pt">
               <mn>0</mn>
              </mstyle>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msubsup>
             <msup>
              <mi>m</mi>
              <mstyle mathsize="8pt">
               <mn>2</mn>
              </mstyle>
             </msup>
             <msup>
              <mi>v</mi>
              <mstyle mathsize="8pt">
               <mn>4</mn>
              </mstyle>
             </msup>
            </mrow>
           </mfrac>
           <mfrac>
            <mn>1</mn>
            <mrow>
             <msup>
              <mtext>sen</mtext>
              <mstyle mathsize="8pt">
               <mn>4</mn>
              </mstyle>
             </msup>
             <mfrac>
              <mi>ϑ</mi>
              <mn>2</mn>
             </mfrac>
            </mrow>
           </mfrac>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{w rSub { size 8{&quot;Effettiva&quot;} } =F times s times n times w rSub { size 8{&quot;Unitaria&quot;} } = ital &quot;Fsn&quot; {  {q rSup { size 8{2} } Q rSup { size 8{2} } }  over  {&quot;64&quot;π rSup { size 8{2} } ε rSub { size 8{0} }  rSup { size 8{2} } m rSup { size 8{2} } v rSup { size 8{4} } } }  {  {1}  over  {&quot;sen&quot; rSup { size 8{4} }  {  {ϑ}  over  {2} } } } } {}</annotation>
       </semantics>
      </math>
