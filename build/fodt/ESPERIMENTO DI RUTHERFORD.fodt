      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>al secondo membro e troviamo una seconda soluzione <draw:frame draw:style-name="fr8" draw:name="Object75" text:anchor-type="as-char" svg:width="0.2335in" svg:height="0.2665in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <msub>
           <mi>ψ</mi>
