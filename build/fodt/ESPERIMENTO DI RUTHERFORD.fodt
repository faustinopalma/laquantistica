           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{z= -  infinity } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
