             <mrow>
              <mo stretchy="false">−</mo>
              <mi mathvariant="italic">iωt</mi>
             </mrow>
            </mstyle>
           </msup>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ψ left (x,y,z,t right )=ψ left (x,y,z right )e rSup { size 8{ - iωt} } } {}</annotation>
       </semantics>
      </math>
