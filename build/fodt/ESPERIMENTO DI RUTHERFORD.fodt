           <mo stretchy="false">=</mo>
           <mn>0</mn>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{ϑ=0} {}</annotation>
       </semantics>
      </math>
