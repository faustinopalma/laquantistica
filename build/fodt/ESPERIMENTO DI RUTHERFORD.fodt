              <mtext>Effettiva</mtext>
             </mstyle>
            </msub>
            <mo stretchy="false">=</mo>
            <mrow/>
           </mrow>
           <mrow>
            <mtable>
             <mtr>
              <mtd>
               <mrow>
                <mrow>
                 <mo fence="true" form="prefix" stretchy="true">(</mo>
                 <mrow>
                  <mrow>
                   <mrow>
                    <mtext>Densità di </mtext>
                    <mrow/>
                   </mrow>
                   <mrow/>
                  </mrow>
                 </mrow>
                 <mo fence="true" form="postfix" stretchy="true">)</mo>
                </mrow>
                <mrow/>
               </mrow>
              </mtd>
             </mtr>
             <mtr>
              <mtd>
               <mrow/>
              </mtd>
             </mtr>
            </mtable>
            <mrow/>
           </mrow>
          </mrow>
          <mrow/>
         </mrow>
        </mstyle>
