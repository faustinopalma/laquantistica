                 <mi mathvariant="normal">Ω</mi>
                </mstyle>
               </msub>
              </mstyle>
             </munder>
             <mrow>
              <mover accent="true">
               <mi>s</mi>
               <mo stretchy="false">¯</mo>
              </mover>
              <mo stretchy="false">⋅</mo>
              <mover accent="true">
               <mi>n</mi>
               <mo stretchy="false">^</mo>
              </mover>
             </mrow>
            </mrow>
           </mrow>
           <mi mathvariant="italic">dΣ</mi>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
