   <text:p text:style-name="Standard">Ora, per risolvere il nostro problema, proviamo a separare le variabili spazio dalle variabili tempo con funzioni del tipo <draw:frame draw:style-name="fr8" draw:name="Object66" text:anchor-type="as-char" svg:width="2.0417in" svg:height="0.2752in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mi>ψ</mi>
           <mrow>
            <mrow>
             <mo fence="true" form="prefix" stretchy="true">(</mo>
             <mrow>
              <mrow>
               <mi>x</mi>
               <mi>,</mi>
               <mi>y</mi>
               <mi>,</mi>
               <mi>z</mi>
               <mi>,</mi>
               <mi>t</mi>
              </mrow>
             </mrow>
             <mo fence="true" form="postfix" stretchy="true">)</mo>
            </mrow>
            <mo stretchy="false">=</mo>
            <mi>ψ</mi>
           </mrow>
           <mrow>
            <mo fence="true" form="prefix" stretchy="true">(</mo>
            <mrow>
             <mrow>
              <mi>x</mi>
              <mi>,</mi>
              <mi>y</mi>
              <mi>,</mi>
              <mi>z</mi>
             </mrow>
            </mrow>
            <mo fence="true" form="postfix" stretchy="true">)</mo>
           </mrow>
           <msup>
            <mi>e</mi>
