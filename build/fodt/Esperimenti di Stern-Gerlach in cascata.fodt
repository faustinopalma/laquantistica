   <text:p text:style-name="Standard">dove abbiamo introdotto la variabile <text:span text:style-name="T1"></text:span>=2<text:span text:style-name="T1"></text:span>/<text:span text:style-name="T1"></text:span>.</text:p>
   <text:p text:style-name="Standard">Ora facciamo i seguenti calcoli matematici.</text:p>
