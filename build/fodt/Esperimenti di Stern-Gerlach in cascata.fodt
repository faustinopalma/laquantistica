            <mtext>cos</mtext>
            <mstyle mathsize="8pt">
             <mn>2</mn>
            </mstyle>
           </msup>
           <mfrac>
            <mi>ϑ</mi>
            <mn>2</mn>
           </mfrac>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{&quot;cos&quot; rSup { size 8{2} }  {  {ϑ}  over  {2} } } {}</annotation>
       </semantics>
