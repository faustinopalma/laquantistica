              <mstyle mathsize="8pt">
               <mrow>
                <mo stretchy="false">−</mo>
                <mrow/>
               </mrow>
              </mstyle>
             </msub>
            </mrow>
            <mo fence="true" form="postfix" stretchy="false">|</mo>
           </mrow>
           <mstyle mathsize="8pt">
