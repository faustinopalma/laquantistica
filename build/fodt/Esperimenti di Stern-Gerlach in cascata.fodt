   <text:p text:style-name="P5">Prima dobbiamo prendere il ket normalizzato <draw:frame draw:style-name="fr3" draw:name="Object105" text:anchor-type="as-char" svg:width="0.2752in" svg:height="0.2917in"><draw:object>
