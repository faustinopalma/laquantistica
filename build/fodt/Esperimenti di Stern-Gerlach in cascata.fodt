    </draw:frame>Sommiamo e prendiamone il modulo quadrato</text:p>
   <text:p text:style-name="Standard">Otteniamo il risultato: <draw:frame draw:style-name="fr3" draw:name="Object25" text:anchor-type="as-char" svg:width="2.4752in" svg:height="0.5665in"><draw:object>
