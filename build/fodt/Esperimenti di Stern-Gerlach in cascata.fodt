                <msub>
                 <mi>m</mi>
                 <mstyle mathsize="8pt">
                  <mtext>90</mtext>
                 </mstyle>
                </msub>
                <mtext>=+</mtext>
                <mi>k</mi>
                <mo stretchy="false">→</mo>
               </mrow>
               <mrow/>
              </mrow>
             </mstyle>
