           <mrow>
            <mi>t</mi>
            <mo stretchy="false">−</mo>
            <msub>
             <mi>t</mi>
             <mstyle mathsize="8pt">
              <mn>0</mn>
             </mstyle>
            </msub>
           </mrow>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{Δt=t - t rSub { size 8{0} } } {}</annotation>
       </semantics>
      </math>
