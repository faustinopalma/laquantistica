    </draw:frame><text:s/>è la probabilità di ottenere <text:span text:style-name="T2">m</text:span><text:span text:style-name="T3">0</text:span><text:span text:style-name="T2">=+k</text:span>, analogamente per <text:span text:style-name="T7"></text:span><text:span text:style-name="T3">-</text:span> e per <draw:frame draw:style-name="fr3" draw:name="Object98" text:anchor-type="as-char" svg:width="0.3583in" svg:height="0.3165in"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <msup>
           <mrow>
            <mo fence="true" form="prefix" stretchy="false">|</mo>
