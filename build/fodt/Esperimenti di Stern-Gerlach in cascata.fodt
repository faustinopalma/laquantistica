      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>e le “condizioni ambientali”. Ci chiediamo quale sarà il ket di stato <draw:frame draw:style-name="fr3" draw:name="Object125" text:anchor-type="as-char" svg:width="0.3165in" svg:height="0.2917in"><draw:object>
