   <text:p text:style-name="Standard">quando sfasiamo lo stato <text:span text:style-name="T2">m</text:span><text:span text:style-name="T3">90</text:span><text:span text:style-name="T2">=-k</text:span> moltiplichiamo i suoi due numeri per <text:span text:style-name="T2">e</text:span><text:span text:style-name="T5">i</text:span><text:span text:style-name="T6"></text:span> </text:p>
