 left lbrace m rSub { size 8{0} } &quot;=+&quot;k&quot;    con probabilità 0,5&quot; {} # 
 right none  left lbrace m rSub { size 8{0} } = - k&quot;    con probabilità 0,5&quot; {} # 
 right no } }  lbrace }  {} # 
&quot;caso 2&quot; rightarrow alignl { stack {
 left lbrace m rSub { size 8{0} } &quot;=+&quot;k&quot;    con probabilità 0,5&quot; {} # 
 right none  left lbrace m rSub { size 8{0} } = - k&quot;    con probabilità 0,5&quot; {} # 
 right no } }  lbrace  {} # 
&quot;caso 3&quot; rightarrow alignl { stack {
 left lbrace m rSub { size 8{0} } &quot;=+&quot;k&quot;    con probabilità 1&quot; {} # 
 right none  left lbrace m rSub { size 8{0} } = - k&quot;    con probabilità 0&quot; {} # 
 right no } }  lbrace  {} 
} } {}</annotation>
