    </draw:frame>Possiamo considerare un esperimento che abbiamo già eseguito (Esperimento numero 4) di cui riportiamo la figura. </text:p>
   <text:p text:style-name="Standard"><draw:custom-shape text:anchor-type="char" draw:z-index="0" draw:name="Text Box 62" draw:style-name="gr8" draw:text-style-name="P4" svg:width="1.5004in" svg:height="0.4004in" svg:x="4.8189in" svg:y="1.0673in">
     <text:p text:style-name="Frame_20_contents">Esperimento n.4</text:p>
     <draw:enhanced-geometry draw:mirror-horizontal="false" draw:mirror-vertical="false" draw:glue-points="?f0 0 0 ?f1 ?f0 ?f2 ?f3 ?f1" draw:text-areas="0 0 ?f3 ?f2" svg:viewBox="0 0 0 0" draw:type="ooxml-rect" draw:enhanced-path="M 0 0 L ?f3 0 ?f3 ?f2 0 ?f2 Z N">
      <draw:equation draw:name="f0" draw:formula="logwidth/2"/>
      <draw:equation draw:name="f1" draw:formula="logheight/2"/>
      <draw:equation draw:name="f2" draw:formula="logheight"/>
      <draw:equation draw:name="f3" draw:formula="logwidth"/>
     </draw:enhanced-geometry>
    </draw:custom-shape>Supponiamo di poter ruotare la prima macchina di un angolo <text:span text:style-name="T7"></text:span>, così in ingresso abbiamo atomi nello stato <draw:frame draw:style-name="fr3" draw:name="Object129" text:anchor-type="as-char" svg:width="1.3165in" svg:height="0.2917in"><draw:object>
