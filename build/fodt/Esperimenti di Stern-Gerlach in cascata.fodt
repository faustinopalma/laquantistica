              <mrow>
               <mrow>
                <mo fence="true" form="prefix" stretchy="true">(</mo>
                <mrow>
                 <mrow>
                  <mrow>
                   <msub>
                    <mi>α</mi>
                    <mstyle mathsize="8pt">
                     <mn>1</mn>
                    </mstyle>
                   </msub>
                   <mrow/>
                  </mrow>
                  <mrow/>
                 </mrow>
                </mrow>
                <mo fence="true" form="postfix" stretchy="true">)</mo>
               </mrow>
               <mrow/>
              </mrow>
             </mtd>
            </mtr>
            <mtr>
             <mtd>
              <mrow/>
             </mtd>
            </mtr>
           </mtable>
           <mrow/>
          </mrow>
          <mrow/>
         </mrow>
        </mstyle>
