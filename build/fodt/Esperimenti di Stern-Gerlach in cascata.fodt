         TGliZXJhdGlvbiBTZXJpZgAAAAAAAPAAAAAAAAAAAAAFAAAAAAACAP8DAAAAAAAAAAEA/wMA
         AAAAAAAAAAAAAIgAAQACAAAAAQCHAAEABQAAAP////8AhgABAAQAAAAAAAAAcgACABcAAAAM
         AAAA1wAAAAEAZ3gAAAAAAAEAAQBnAIwAAQAAAAAAjAABAAAAAACMAAEAAAAAAA==
        </office:binary-data>
       </draw:image>
      </draw:frame>.</text:p>
    </text:list-item>
    <text:list-item>
     <text:p text:style-name="P9">Un qualsiasi altro stato <text:span text:style-name="T7"></text:span> può essere considerato come una sovrapposizione degli autostati di una grandezza <text:span text:style-name="T2">g</text:span> e può essere rappresentato da un vettore di numeri complessi <draw:frame draw:style-name="fr3" draw:name="Object157" text:anchor-type="as-char" svg:width="0.85in" svg:height="0.8752in"><draw:object>
