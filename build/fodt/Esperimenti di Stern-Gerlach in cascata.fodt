   <text:p text:style-name="P5">Infine dobbiamo calcolare la componente del ket <draw:frame draw:style-name="fr3" draw:name="Object108" text:anchor-type="as-char" svg:width="0.2752in" svg:height="0.2917in"><draw:object>
