                  <mrow>
                   <mo fence="true" form="prefix" stretchy="true">(</mo>
                   <mrow>
                    <mrow>
                     <mrow>
                      <mn>1</mn>
                      <mrow/>
                     </mrow>
                     <mrow/>
                    </mrow>
                   </mrow>
                   <mo fence="true" form="postfix" stretchy="true">)</mo>
                  </mrow>
                  <mrow/>
                 </mrow>
                </mtd>
               </mtr>
               <mtr>
                <mtd>
                 <mrow/>
                </mtd>
               </mtr>
              </mtable>
              <mrow/>
