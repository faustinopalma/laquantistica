   <text:p text:style-name="Standard">sostituendo per <text:span text:style-name="T1">E</text:span> la formula <draw:frame draw:style-name="fr7" draw:name="Object28" text:anchor-type="as-char" svg:width="0.4465in" svg:height="0.1854in" draw:z-index="21"><draw:object>
