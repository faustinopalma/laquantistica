       AAAAAA==
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è l’energia necessaria a superare la differenza di potenziale e, quando <draw:frame draw:style-name="fr7" draw:name="Object11" text:anchor-type="as-char" svg:width="0.7374in" svg:height="0.222in" draw:z-index="4"><draw:object>
