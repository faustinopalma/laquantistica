      <text:p text:style-name="P7">Voltmetro</text:p>
     </draw:text-box>
    </draw:frame><draw:frame draw:style-name="fr4" draw:name="Frame23" text:anchor-type="char" svg:x="0.0189in" svg:y="1.6165in" svg:width="0.8in" svg:height="0.6in" draw:z-index="71">
     <draw:text-box>
      <text:p text:style-name="P7">Voltmetro</text:p>
     </draw:text-box>
    </draw:frame><draw:frame draw:style-name="fr4" draw:name="Frame24" text:anchor-type="char" svg:x="3.6291in" svg:y="1.6543in" svg:width="1.1in" svg:height="0.6in" draw:z-index="70">
     <draw:text-box>
      <text:p text:style-name="P8">Separatore</text:p>
      <text:p text:style-name="P8">di</text:p>
