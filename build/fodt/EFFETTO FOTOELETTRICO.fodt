      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADtQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADALgAWAFEgAAACYGDwAaAP////8AABAAAADA////
       NwAAACAFAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AkD+AAAAAAAAkAEBAAAA
