   <text:p text:style-name="P14"><draw:frame draw:style-name="fr4" draw:name="Frame30" text:anchor-type="char" svg:x="5.0189in" svg:y="0.2083in" svg:width="1.3in" svg:height="0.6236in" draw:z-index="76">
     <draw:text-box>
      <text:p text:style-name="Standard"><text:span text:style-name="T5">Frequenza (10</text:span><text:span text:style-name="T8">14</text:span><text:span text:style-name="T5">Hz)</text:span></text:p>
     </draw:text-box>
    </draw:frame></text:p>
   <text:p text:style-name="Standard"/>
   <text:p text:style-name="Standard"/>
   <text:p text:style-name="Standard">Si osserva che i punti si dispongono su una retta con una pendenza di <draw:frame draw:style-name="fr7" draw:name="Object14" text:anchor-type="as-char" svg:width="1.9791in" svg:height="0.211in" draw:z-index="7"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <mrow>
            <mn>3,6</mn>
            <mo stretchy="false">⋅</mo>
            <msup>
             <mtext>10</mtext>
             <mstyle mathsize="8pt">
              <mrow>
               <mo stretchy="false">−</mo>
               <mtext>15</mtext>
              </mrow>
             </mstyle>
            </msup>
           </mrow>
           <mrow>
            <msup>
             <mtext>eVs</mtext>
             <mstyle mathsize="8pt">
              <mn>2</mn>
             </mstyle>
            </msup>
            <mo stretchy="false">≡</mo>
            <mrow>
             <mn>5,8</mn>
             <mo stretchy="false">⋅</mo>
             <msup>
              <mtext>10</mtext>
              <mstyle mathsize="8pt">
               <mrow>
                <mo stretchy="false">−</mo>
                <mtext>34</mtext>
               </mrow>
              </mstyle>
             </msup>
            </mrow>
           </mrow>
           <msup>
            <mtext>Js</mtext>
            <mstyle mathsize="8pt">
             <mn>2</mn>
            </mstyle>
           </msup>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{3,6 cdot &quot;10&quot; rSup { size 8{ - &quot;15&quot;} } &quot;eVs&quot; rSup { size 8{2} }  equiv 5,8 cdot &quot;10&quot; rSup { size 8{ - &quot;34&quot;} } &quot;Js&quot; rSup { size 8{2} } } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADawEAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAiAUEgAAACYGDwAaAP////8AABAAAADA////
