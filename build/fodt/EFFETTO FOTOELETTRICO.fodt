     </draw:image>
    </draw:frame><text:span text:style-name="T1">,</text:span> dove <draw:frame draw:style-name="fr7" draw:name="Object8" text:anchor-type="as-char" svg:width="0.1661in" svg:height="0.222in" draw:z-index="1"><draw:object>
