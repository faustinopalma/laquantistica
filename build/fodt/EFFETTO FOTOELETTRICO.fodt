       AiJTeXN0ZW0AAAQAAAAtAQAABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>posseduta dagli elettroni; infatti il prodotto <draw:frame draw:style-name="fr7" draw:name="Object10" text:anchor-type="as-char" svg:width="0.4217in" svg:height="0.222in" draw:z-index="3"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <mrow>
           <msub>
            <mi>q</mi>
            <mstyle mathsize="8pt">
             <mi>e</mi>
            </mstyle>
           </msub>
           <mi mathvariant="italic">ΔV</mi>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{q rSub { size 8{e} } ΔV} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
