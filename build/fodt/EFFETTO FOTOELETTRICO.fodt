       AAAAAAECAiJTeXN0ZW0AAAQAAAAtAQAABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame>. Per i fotoni abbiamo <draw:frame draw:style-name="fr7" draw:name="Object26" text:anchor-type="as-char" svg:width="0.3327in" svg:height="0.1854in" draw:z-index="19"><draw:object>
