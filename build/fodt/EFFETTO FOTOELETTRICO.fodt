           <mo stretchy="false">=</mo>
           <mi>c</mi>
          </mrow>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{v=c} {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADtQAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAKAAcADEgAAACYGDwAaAP////8AABAAAADA////
       NwAAAIADAAC3AQAACwAAACYGDwAMAE1hdGhUeXBlAAAwABUAAAD7AkD+AAAAAAAAkAEBAAAA
       BAIAEFRpbWVzIE5ldyBSb21hbgAAwwQAAAAtAQAACAAAADIKIAGxAgEAAABjAAgAAAAyCiAB
       MgABAAAAdgAQAAAA+wJA/gAAAAAAAJABAAAAAgQCABBTeW1ib2wAAgQAAAAtAQEABAAAAPAB
       AAAIAAAAMgogAWABAQAAAD0ACgAAACYGDwAKAP////8BAAAAAAAQAAAA+wIUAAkAAAAAALwC
       AAAAAAECAiJTeXN0ZW0AAAQAAAAtAQAABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>quindi:</text:p>
   <text:p text:style-name="Standard"><text:tab/><draw:frame draw:style-name="fr7" draw:name="Object27" text:anchor-type="as-char" svg:width="1.5618in" svg:height="0.3953in" draw:z-index="20"><draw:object>
