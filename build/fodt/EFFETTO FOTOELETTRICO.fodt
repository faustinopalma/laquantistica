      <text:p text:style-name="P13"><draw:frame draw:style-name="fr13" draw:name="Frame29" text:anchor-type="char" svg:x="5.6189in" svg:y="0.1764in" svg:width="0.8in" svg:height="0.6236in" draw:z-index="74">
