       AiJTeXN0ZW0AAAQAAAAtAQAABAAAAPABAQADAAAAAAA=
      </office:binary-data>
     </draw:image>
    </draw:frame><text:s/>è la carica dell’elettrone, è appena superiore all’energia <draw:frame draw:style-name="fr7" draw:name="Object9" text:anchor-type="as-char" svg:width="0.1925in" svg:height="0.222in" draw:z-index="2"><draw:object>
      <math xmlns="http://www.w3.org/1998/Math/MathML" display="block">
       <semantics>
        <mrow>
         <mstyle mathsize="12pt">
          <msub>
           <mi>E</mi>
           <mstyle mathsize="8pt">
            <mi>e</mi>
           </mstyle>
          </msub>
         </mstyle>
         <mrow/>
        </mrow>
        <annotation encoding="StarMath 5.0"> size 12{E rSub { size 8{e} } } {}</annotation>
       </semantics>
      </math>
     </draw:object><draw:image>
      <office:binary-data>AQAJAAADsgAAAAIAFQAAAAAABQAAAAkCAAAAAAQAAAACAQEABQAAAAEC////AAQAAAAuARgA
       BQAAADECAQAAAAUAAAALAgAAAAAFAAAADAJgAgACEgAAACYGDwAaAP////8AABAAAADA////
       t////8ABAAAXAgAACwAAACYGDwAMAE1hdGhUeXBlAABgABUAAAD7AiD/AAAAAAAAkAEBAAAA
